# Telegram bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram numeric user IDs allowed to use the bot.
ALLOWED_TELEGRAM_USER_IDS=

# Local Ollama chat settings.
OLLAMA_HOST=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e2b
OLLAMA_THINKING=medium
OLLAMA_CONTEXT_TOKENS=32768

# Runtime settings override selected .env values when saved through the bot UI.
RUNTIME_SETTINGS_PATH=data/settings.json

# Local voice transcription.
# ggml-large-v3-turbo-q5_0 is the fast local default through whisper.cpp.
# Runtime settings can override this value through the Telegram /voice_model command.
WHISPER_BIN=whisper
WHISPER_MODEL=ggml-large-v3-turbo-q5_0
WHISPER_MODEL_DIR=~/.cache/whisper
WHISPER_DEVICE=auto
WHISPER_BEAM_SIZE=5
WHISPER_THREADS=0
WHISPER_LANGUAGE=
WHISPER_ALLOW_DOWNLOAD=false
WHISPER_FP16=False
WHISPER_CPP_BIN=
WHISPER_CPP_MODEL_DIR=
WHISPER_CPP_THREADS=4

# Optional: used by Ollama client when needed.
OLLAMA_API_KEY=

# Required for Tavily-backed web_search and web_fetch tools.
TAVILY_API_KEY=

# Optional public-profile research PDF tool. Disabled by default.
HUMAN_RESEARCH_ENABLED=false

# Local video download wrapper used by the yt-download tool.
YT_DOWNLOAD_SCRIPT=~/Movies/ShortsToProcess/video-dl.sh
SHORTS_COOKIES_FILE=~/Movies/ShortsToProcess/cookies/instagram-cookies.txt
SHORTS_COOKIES_FROM_BROWSER=
SHORTS_COOKIES_TIMEOUT_SECONDS=8

# Optional remote webhook subscription for audio uploads.
# When WEBHOOK_URL is empty, the bot runs without webhook polling.
WEBHOOK_URL=
WEBHOOK_UPLOAD_PASSWORD=
WEBHOOK_CONTROL_PASSWORD=
WEBHOOK_POLL_TIMEOUT_SECONDS=25

# Webhook server runtime settings for a separate deployment, for example on Coolify.
WEBHOOK_BIND_HOST=0.0.0.0
WEBHOOK_PORT=3000
WEBHOOK_AUDIO_DIR=data/webhook-audio
WEBHOOK_STORAGE_PATH=data/webhook-state.json
WEBHOOK_MAX_AUDIO_BYTES=20971520

# Telegram live-response behavior.
TELEGRAM_STREAM_DRAFTS=true
TELEGRAM_SEND_FINAL_MESSAGE=true
TELEGRAM_POLL_TIMEOUT_SECONDS=30

# Telegram UI behavior.
# Inline mode implementation exists, but it is disabled by default.
TELEGRAM_ENABLE_INLINE_MODE=false

# commands: show Telegram command menu near the message field.
# default: restore Telegram default menu button.
# web_app: launch a Telegram Web App; requires TELEGRAM_MENU_WEB_APP_URL.
# none: do not configure the menu button on startup.
TELEGRAM_MENU_BUTTON=commands
TELEGRAM_MENU_WEB_APP_TEXT=Open tools
TELEGRAM_MENU_WEB_APP_URL=

# Local cron scheduler. Task registrations are stored in JSON and recovered on restart.
CRON_ENABLED=true
CRON_STORAGE_PATH=data/cron-tasks.json
CRON_TICK_MS=15000
CRON_COMMAND_TIMEOUT_MS=120000
CRON_ALLOW_SEND_MESSAGE_TOOL=true

# Local reminder scheduler. One-time reminders are stored in JSON and archived after delivery.
REMINDER_ENABLED=true
REMINDER_STORAGE_PATH=data/reminders.json
REMINDER_ARCHIVE_DIR=data/reminders-done
REMINDER_TICK_MS=60000

# Codex CLI delegation tool.
CODEX_COMMAND=codex-proxy
CODEX_MODEL=gpt-5.3-codex
CODEX_REASONING=high
CODEX_WORKSPACE=~/web/my-local-bro-workspace
CODEX_TIMEOUT_MS=1200000
CODEX_SHELL=/bin/zsh
CODEX_SOURCE_ZSHRC=true
